# Recommended: run the Chinese Qwen3 embedding model through SiliconFlow.
# Use "sentence-transformers" for the optional offline provider and "local"
# only for deterministic tests or demos.
EMBEDDING_PROVIDER=openai
# Preferred for OpenAI-compatible services such as SiliconFlow. This avoids
# collisions with an OPENAI_API_KEY inherited from the host environment.
EMBEDDING_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024
# Remote embedding requests are split into bounded batches. The SDK retries
# rate limits and transient server errors with exponential backoff.
OPENAI_EMBEDDING_BATCH_SIZE=8
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=4
# Leave blank to reuse LOCAL_EMBEDDING_QUERY_INSTRUCTION.
OPENAI_EMBEDDING_QUERY_INSTRUCTION=

# Local semantic embedding settings. "auto" selects MPS on Apple Silicon.
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
LOCAL_EMBEDDING_CACHE_PATH=.model-cache/huggingface
LOCAL_EMBEDDING_DEVICE=auto
LOCAL_EMBEDDING_BATCH_SIZE=8
LOCAL_EMBEDDING_QUERY_INSTRUCTION=Given an Android technical interview question, retrieve relevant knowledge-base documents that answer the question
LOCAL_EMBEDDING_TRUST_REMOTE_CODE=false
# Keep these at 0 for the first model download. Change to 1 afterwards.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Paths may be absolute or relative to the repository root.
KNOWLEDGE_BASE_PATH=knowledge-base
CHROMA_PERSIST_PATH=.chroma
CHROMA_COLLECTION=android_knowledge_siliconflow_qwen3_06b_1024_v1
MCP_TRANSPORT=stdio
